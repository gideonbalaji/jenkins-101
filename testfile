pipeline {
    agent { label 'docker-agent-python' }

    stages {
        stage('Build') {
            steps {
                echo 'Installing dependencies...'
                sh '''
                    cd myapp
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Test') {
            steps {
                echo 'Running unit tests...'
                sh '''
                    . myapp/venv/bin/activate
                    mkdir -p tests
                    # Replace with your test command (pytest, nose, etc.)
                    touch tests/__init__.py
                    echo "import unittest
class TestSample(unittest.TestCase):
    def test_pass(self):
        self.assertTrue(True)" > tests/test_basic.py

            # Run discovery
            python3 -m unittest discover -v tests
        '''
            }
        }

        stage('Deliver') {
            steps {
                echo 'Packaging and Delivering...'
                sh '''
            TARGET_FILE=$(find . -name "main.py" | head -n 1)
            
            if [ -z "$TARGET_FILE" ]; then
                echo "ERROR: main.py not found anywhere in the workspace!"
                ls -R
                exit 1
            fi
            
            echo "Found main.py at: $TARGET_FILE"
            
            . myapp/venv/bin/activate || echo "No venv found, using system python"
            
            # 3. Run it using the discovered path
            python3 "$TARGET_FILE" --help
        '''
                // In a real scenario, you might use 'archiveArtifacts' here
                archiveArtifacts artifacts: 'dist/*', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            echo 'Cleaning up workspace...'
            // Optional: delete the venv to save space
            // deleteDir() 
        }
        success {
            echo 'Build Successful!'
        }
        failure {
            echo 'Build Failed. Checking logs...'
        }
    }
}
